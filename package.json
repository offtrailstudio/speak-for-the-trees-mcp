{
  "name": "@offtrailstudio/speak-for-the-trees",
  "version": "0.1.0",
  "description": "MCP server for investigating ecosystem health using public environmental data",
  "license": "MIT",
  "author": "Robinson Greig",
  "repository": {
    "type": "git",
    "url": "https://github.com/offtrailstudio/speak-for-the-trees.git"
  },
  "keywords": [
    "mcp",
    "environment",
    "ecosystem",
    "water-quality",
    "conservation",
    "open-data",
    "epa",
    "usgs"
  ],
  "type": "module",
  "bin": {
    "speak-for-the-trees": "./dist/server.js"
  },
  "files": [
    "dist",
    "AGENT.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/server.ts --format esm --dts",
    "dev": "tsx src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
